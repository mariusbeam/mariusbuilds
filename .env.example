# Copy to .env for local overrides (optional — dev uses local files by default).
#
# Required on Netlify (production) if you want /keystatic on the live site.
# Get the value from https://keystatic.cloud → your project → Settings.
#
# Format: team-slug/project-slug   (example: mariusbuilds/mariusbuilds)
KEYSTATIC_CLOUD_PROJECT=

# Umami analytics (optional — loaded only after analytics cookie consent)
# Host without protocol, e.g. cloud.umami.is or analytics.example.com
PUBLIC_UMAMI_HOST=
PUBLIC_UMAMI_WEBSITE_ID=
