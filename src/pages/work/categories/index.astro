---
import BaseLayout from "@layouts/BaseLayout.astro";
import WorkCategoryCloud from "@components/CategoryCloud/WorkCategoryCloud.astro";
import Badge from "@components/Badge/Badge.astro";

import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";

const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
---

<BaseLayout title={`Work categories | ${siteData.name}`} description="Browse case studies by category.">
  <section class="site-container py-24 md:py-32">
    <div class="mx-auto max-w-3xl text-center">
      <Badge>Work</Badge>
      <h1 class="h1 mt-4">Categories</h1>
      <p class="description mt-6 text-lg">Filter case studies by industry or project type.</p>
    </div>
    <div class="mt-12">
      <WorkCategoryCloud showCount={true} />
    </div>
  </section>
</BaseLayout>
