---
import BaseLayout from "@layouts/BaseLayout.astro";
import WorkPostCard from "@components/PostCard/WorkPostCard.astro";
import WorkCategoryCloud from "@components/CategoryCloud/WorkCategoryCloud.astro";
import Badge from "@components/Badge/Badge.astro";

import { getAllWork } from "@js/workUtils";
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";

const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
const caseStudies = await getAllWork(currLocale);
---

<BaseLayout
  title={`Work | ${siteData.name}`}
  description="Real problems. Real builds. Real results."
>
  <section class="site-container">
    <div
      class="overflow-x-clip bg-[url('/assets/pattern-light.svg')] bg-center bg-no-repeat pt-24 md:pt-32 dark:bg-[url('/assets/pattern-dark.svg')]"
    >
      <div class="mx-auto flex max-w-[950px] flex-col justify-center">
        <div class="mx-auto">
          <Badge>Work</Badge>
        </div>
        <h1 class="h1 text-center">Real problems. Real builds. Real results.</h1>
        <p class="description mx-auto mt-6 max-w-2xl text-center text-lg text-pretty md:text-xl">
          Case studies from projects where a custom tool or site solved a specific business problem.
        </p>
      </div>

      <div class="mt-20 flex pb-8 md:mt-28">
        <WorkCategoryCloud />
      </div>
    </div>

  {
    caseStudies.length > 0 ? (
      <div class="grid gap-8 gap-y-10 md:grid-cols-2">
        {caseStudies.map((post) => (
          <WorkPostCard post={post} showDescription={true} data-mos="fade-up" />
        ))}
      </div>
    ) : (
      <p class="description pb-24 text-center text-lg">
        Case studies are on the way. Add your first one in the CMS under <strong>Case studies</strong>.
      </p>
    )
  }
  </section>
</BaseLayout>
