---
import { type InferGetStaticPropsType } from "astro";
import { render } from "astro:content";

import WorkLayoutCenter from "@layouts/WorkLayoutCenter.astro";
import ExternalLink from "@components/MarkdownComponents/ExternalLink.astro";

import { getAllWork } from "@js/workUtils";
import { defaultLocale } from "@config/siteSettings.json";

export async function getStaticPaths() {
  const posts = await getAllWork(defaultLocale);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const post = Astro.props as Props;
const { Content } = await render(post);
---

<WorkLayoutCenter post={post}>
  <Content components={{ a: ExternalLink }} />
</WorkLayoutCenter>
