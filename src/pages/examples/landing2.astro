---
// layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import Hero from "@components/Hero/HeroBgImage.astro";
import Awards from "@components/Awards/Awards.astro";
import FeatureSideImage from "@components/Feature/FeatureSideImage.astro";
import ServicesIcon from "@components/Services/ServicesIcon.astro";
import FeatureVideo from "@components/Feature/FeatureVideo.astro";
import TestimonialsColumns from "@components/Testimonials/TestimonialsColumns.astro";
import FeatureToggleImage from "@components/Feature/FeatureToggleImage.astro";
import CtaCenter from "@components/Cta/CtaCenter.astro";
import FaqCards from "@components/Faq/FaqCards.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
const faqData = getTranslatedData("faqData", currLocale);

const landing2Services = {
  badge: "Services",
  title: "Our professional services",
  description:
    "Lorem ipsum dolor sit amet consectetur, adipisicing elit. Corporis eius sunt autem esse delectus illo vel est optio omnis consectetur eos dignissimos.",
  items: [
    {
      icon: "tabler/home",
      title: "Exterior",
      text: "Professional home exterior painting, including siding, doors, and trim.",
      href: "/services/exterior-painting/",
    },
    {
      icon: "tabler/sofa",
      title: "Interior",
      text: "Our experienced staff can paint your home's interior, including walls, ceilings, and trim.",
      href: "/services/interior-painting/",
    },
    {
      icon: "tabler/fence",
      title: "Deck and Fence",
      text: "Stain your deck or fence to keep it looking great and protected from the elements.",
      href: "/services/deck-and-fence-staining/",
    },
  ],
};
---

<BaseLayout title={siteData.title} description={siteData.description}>
  <Hero />
  <!-- <Awards /> -->
  <FeatureVideo />
  <ServicesIcon content={landing2Services} />
  <FeatureSideImage />
  <TestimonialsColumns />
  <FeatureToggleImage />
  <CtaCenter />
  <FaqCards
    content={{
      badge: "FAQ",
      title: "Frequently Asked Questions",
      items: faqData,
    }}
  />
</BaseLayout>
