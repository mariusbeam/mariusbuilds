---
import { type CollectionEntry, getCollection, render } from "astro:content";

// layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import ExternalLink from "@components/MarkdownComponents/ExternalLink.astro";
import CookieSettingsPanel from "@components/CookieConsent/CookieSettingsPanel.astro";

// utils
import { filterCollectionByLanguage } from "@js/localeUtils";
import { defaultLocale } from "@config/siteSettings.json";

export async function getStaticPaths() {
  const otherPages: CollectionEntry<"otherPages">[] = await getCollection(
    "otherPages",
    ({ data }) => {
      // filter out draft pages
      return data.draft !== true;
    },
  );

  // get rid of pages from other languages and remove locale from slug
  const filteredPages = filterCollectionByLanguage(otherPages, defaultLocale);

  return filteredPages.map((page) => ({
    params: { page: page.id },
    props: page,
  }));
}

// Catch-all must not swallow asset-like paths (e.g. broken font URLs at /@fontsource/...)
const pageParam = Astro.params.page;
if (
  !pageParam ||
  pageParam.startsWith("@") ||
  pageParam.includes(".") ||
  pageParam.startsWith("_")
) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const page = Astro.props as CollectionEntry<"otherPages">;

// convert markdown to html
const { Content } = await render(page);
const { title, description } = page.data;

const isCookiePolicy = page.id === "cookie-policy" || page.id.endsWith("/cookie-policy");
const pageLocale = page.id.startsWith("fr/") ? "fr" : "en";
---

<BaseLayout title={title} description={description}>
  <section class="site-container mt-16 overflow-x-clip">
    <div
      class="w-full bg-[url('/assets/pattern-light.svg')] bg-center bg-no-repeat py-20 text-center md:py-32 dark:bg-[url('/assets/pattern-dark.svg')]"
    >
      <h1 class="h1">{title}</h1>
    </div>
    <div class="mx-auto max-w-3xl">
      {isCookiePolicy && <CookieSettingsPanel locale={pageLocale} />}
      <div
        class:list={[
          "text-base-content markdown-content max-w-none text-sm md:text-base",
          isCookiePolicy ? "mt-0" : "mt-10",
        ]}
      >
        <Content components={{ a: ExternalLink }} />
      </div>
    </div>
  </section>
</BaseLayout>
