---
/** Query-string tag filter needs request-time rendering (not static HTML). */
export const prerender = false;

import BaseLayout from "@layouts/BaseLayout.astro";
import ToolCard from "@components/ToolCard/ToolCard.astro";
import ToolTagCloud from "@components/ToolTagCloud/ToolTagCloud.astro";
import Badge from "@components/Badge/Badge.astro";

import { getAllTools, filterToolsByTag } from "@js/toolsUtils";
import { getTranslatedData } from "@js/translationUtils";
import { humanize } from "@js/textUtils";

const siteData = getTranslatedData("siteData", "en");
const allTools = await getAllTools("en");

const activeTag = Astro.url.searchParams.get("tag");
const tools = activeTag ? filterToolsByTag(allTools, activeTag) : allTools;
---

<BaseLayout
  title={`Tools | ${siteData.name}`}
  description="Tools I actually use and recommend."
>
  <section class="site-container py-24 md:py-32">
    <div class="mx-auto max-w-3xl text-center">
      <Badge>Tools</Badge>
      <h1 class="h1 mt-4 mb-6">Tools I actually use and recommend.</h1>
      <p class="description text-lg text-pretty md:text-xl">
        A short, opinionated directory. Filter by tag or browse everything.
      </p>
    </div>

    <div class="mt-12">
      <ToolTagCloud activeTag={activeTag} showCount={true} />
    </div>

    {
      activeTag && (
        <p class="description mt-8 text-center text-lg">
          Showing tools tagged <span class="text-base-900 dark:text-white font-semibold">
            {humanize(activeTag)}
          </span>
          —
          <a class="text-primary-500 ml-1 underline" href="/tools" data-astro-reload>
            show all
          </a>
        </p>
      )
    }

    {
      tools.length > 0 ? (
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {tools.map((tool) => (
            <ToolCard tool={tool} data-mos="fade-up" />
          ))}
        </div>
      ) : (
        <p class="description mt-16 text-center text-lg">
          {activeTag
            ? "No tools with this tag yet."
            : "No tools listed yet. Add entries in the CMS under Favourite tools (EN)."}
        </p>
      )
    }
  </section>
</BaseLayout>
