---
/**
 * Homepage services as icon cards (Landing 2 style). Pass `content` from the page.
 * Now supports `illustration` field on items to replace icons with custom SVG illustrations.
 */
import ServiceCard from "@components/ServiceCard/ServiceCardIcon.astro";
import Badge from "@components/Badge/Badge.astro";

interface ServiceItem {
  icon: string;
  illustration?: string;
  title: string;
  text: string;
  href: string;
}

interface SectionContent {
  badge?: string;
  title: string;
  description?: string;
  items: ServiceItem[];
  buttonText?: string;
}

interface Props {
  content?: SectionContent;
}

const themeDefault: SectionContent = {
  badge: "Services",
  title: "Our professional services",
  description:
    "Lorem ipsum dolor sit amet consectetur, adipisicing elit. Corporis eius sunt autem esse delectus illo vel est optio omnis consectetur eos dignissimos.",
  items: [
    {
      icon: "tabler/home",
      title: "Exterior",
      text: "Professional home exterior painting, including siding, doors, and trim.",
      href: "/services/exterior-painting/",
    },
    {
      icon: "tabler/sofa",
      title: "Interior",
      text: "Our experienced staff can paint your home's interior, including walls, ceilings, and trim.",
      href: "/services/interior-painting/",
    },
    {
      icon: "tabler/fence",
      title: "Deck and Fence",
      text: "Stain your deck or fence to keep it looking great and protected from the elements.",
      href: "/services/deck-and-fence-staining/",
    },
  ],
};

const { content = themeDefault } = Astro.props as Props;
const buttonText = content.buttonText ?? "Learn more";
---

<section id="services-icon" class="py-24 md:py-28">
  <div
    class="site-container bg-[url('/assets/pattern-light.svg')] bg-center bg-no-repeat dark:bg-[url('/assets/pattern-dark.svg')]"
  >
    <div class="mx-auto mb-16 text-center md:max-w-4xl" data-mos="fade-up">
      {content.badge && <Badge>{content.badge}</Badge>}
      <h2 class="h2 mb-4">{content.title}</h2>
      {
        content.description && (
          <p class="description text-lg md:text-xl">{content.description}</p>
        )
      }
    </div>
    <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3" id="services-icon-cards">
      {
        content.items.map((feature, idx) => (
          <ServiceCard
            title={feature.title}
            text={feature.text}
            icon={feature.icon}
            illustration={feature.illustration}
            cardNumber={String(idx + 1).padStart(2, "0")}
            href={feature.href}
            buttonText={buttonText}
            idx={idx}
            data-mos="zoom-in"
            data-mos-delay={0.15 * idx}
            data-mos-anchor="#services-icon-cards"
          />
        ))
      }
    </div>
  </div>
</section>
