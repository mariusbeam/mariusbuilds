---
/**
 * Alternating image + text cards. Theme demo defaults — pass `content` from the page for real copy.
 */
import ServiceCard from "@components/ServiceCard/ServiceCardSideImage.astro";
import Badge from "@components/Badge/Badge.astro";

import image1 from "@images/house.jpg";
import image2 from "@images/living-room.jpg";
import image3 from "@images/paint-swatches.jpg";
import image4 from "@assets/images/business-owner-crop.png";

const sectionImages = [image1, image2, image3, image4] as const;

interface ServiceItem {
  title: string;
  details: string;
  href: string;
}

interface SectionContent {
  badge?: string;
  title: string;
  description?: string;
  items: ServiceItem[];
  buttonText?: string;
}

interface Props {
  content?: SectionContent;
}

const themeDefault: SectionContent = {
  badge: "Services",
  title: "Our services will blow you away",
  description:
    "We offer a variety of services for every type of project. When you're ready, contact us to get started.",
  buttonText: "Learn more",
  items: [
    {
      title: "Exterior Painting",
      details:
        "Professional home exterior painting, including siding, doors, and trim. Lorem ipsum dolor sit amet consectetur adipisicing elit.",
      href: "/services/exterior-painting/",
    },
    {
      title: "Interior Painting",
      details:
        "Our experienced staff can paint your home's interior, including walls, ceilings, and trim. Lorem ipsum dolor sit amet consectetur adipisicing elit.",
      href: "/services/interior-painting/",
    },
    {
      title: "Deck and Fence Staining",
      details:
        "Stain your deck or fence to keep it looking great and protected from the elements. Lorem ipsum dolor sit amet consectetur adipisicing elit.",
      href: "/services/deck-and-fence-staining/",
    },
  ],
};

const { content = themeDefault } = Astro.props as Props;
const buttonText = content.buttonText ?? "Learn more";
---

<section id="services-side-image" class="overflow-hidden py-24 md:py-28">
  <div class="site-container">
    <div class="mx-auto mb-16 text-center md:mb-20 md:max-w-4xl" data-mos="fade-up">
      {content.badge && <Badge>{content.badge}</Badge>}
      <h2 class="h2 mb-4">{content.title}</h2>
      {
        content.description && (
          <p class="description text-lg md:text-xl">{content.description}</p>
        )
      }
    </div>
    <div class="flex flex-col gap-16 md:mt-16 md:gap-24">
      {
        content.items.map((feature, idx) => (
          <ServiceCard
            title={feature.title}
            details={feature.details}
            image={sectionImages[idx % sectionImages.length]}
            imageSide={idx % 2 === 0 ? "right" : "left"}
            href={feature.href}
            idx={idx}
            buttonText={buttonText}
          />
        ))
      }
    </div>
  </div>
</section>
