---
import { Icon } from "astro-icon/components";

import type { CollectionEntry } from "astro:content";

import { getFaviconUrl } from "@js/faviconUtils";
import { humanize } from "@js/textUtils";

interface Props {
  tool: CollectionEntry<"tools">;
  class?: string;
}

const { tool, class: className } = Astro.props as Props;
const { name, url, tagline, tags = [] } = tool.data;
const faviconUrl = getFaviconUrl(url);
---

<article
  class:list={[
    "dark:hover:bg-base-900 flex h-full flex-col rounded-md border border-base-200 p-5 transition hover:bg-white hover:shadow-md dark:border-base-800",
    className,
  ]}
>
  <div class="mb-2 flex items-start gap-3">
    <div
      class="bg-base-100 dark:bg-base-800 flex size-10 shrink-0 items-center justify-center overflow-hidden rounded-md border border-base-200 dark:border-base-700"
      aria-hidden="true"
    >
      {
        faviconUrl ? (
          <img
            src={faviconUrl}
            alt=""
            width={32}
            height={32}
            class="size-8 object-contain"
            loading="lazy"
            decoding="async"
            onerror="this.classList.add('hidden');this.parentElement?.querySelector('.tool-card__favicon-fallback')?.classList.remove('hidden')"
          />
        ) : null
      }
      <Icon
        name="tabler/wand"
        class:list={[
          "text-base-400 size-5 tool-card__favicon-fallback",
          faviconUrl && "hidden",
        ]}
      />
    </div>
    <div class="min-w-0 flex-1">
      <h2 class="text-base-900 dark:text-white text-lg font-bold">{name}</h2>
    </div>
  </div>
  {
    tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="bg-base-100 text-base-600 dark:bg-base-800 dark:text-base-300 rounded-full px-2.5 py-0.5 text-xs font-medium">
            {humanize(tag)}
          </span>
        ))}
      </div>
    )
  }
  {tagline && <p class="description mt-3 text-sm text-pretty">{tagline}</p>}
  <a
    href={url}
    class="primary-focus mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary-500 hover:underline"
    target="_blank"
    rel="noopener noreferrer"
  >
    Visit site
    <span class="sr-only">({name})</span>
  </a>
</article>
