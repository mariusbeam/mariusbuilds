---
/**
 * Dark card with illustration, number badge, title, text, link, and button.
 * Matches the card style proof design for the services section.
 *
 * When `illustration` is provided, renders a custom SVG instead of the Tabler icon.
 */

// components
import Button from "@components/Button/Button.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getLocalizedRoute } from "@js/translationUtils";

interface Props {
  icon: string;
  illustration?: string;
  cardNumber?: string;
  title: string;
  text: string;
  href: string;
  buttonText?: string;
  idx: number;
  rest?: any;
}

const { illustration, title, text, href, buttonText = "Learn more", ...rest } = Astro.props as Props;

const currLocale = getLocaleFromUrl(Astro.url);
---

<div {...rest} class="h-full">
  <a
    href={getLocalizedRoute(currLocale, href)}
    class="group flex h-full flex-col items-start gap-5 rounded-2xl border border-white/[0.06] bg-base-900 p-8 transition-colors duration-200 hover:border-white/[0.12]"
  >
    {/* Illustration */}
    {illustration && (
      <div class="flex w-full items-center justify-center">
        <img src={illustration} alt="" class="h-32 w-auto" aria-hidden="true" />
      </div>
    )}

    {/* Title + text */}
    <div class="flex flex-1 flex-col gap-2">
      <h3 class="text-lg font-bold text-[#fdbb3e] leading-snug">{title}</h3>
      <p class="text-sm text-white/80 leading-relaxed">{text}</p>
    </div>

    {/* Button */}
    <div class="mt-auto flex justify-start pt-2">
      <Button variant="outline" arrow="right">
        {buttonText} <span class="sr-only">about {title}</span>
      </Button>
    </div>
  </a>
</div>
