---
import Button from "@components/Button/Button.astro";

interface Props {
  locale?: "en" | "fr";
}

const { locale = "en" } = Astro.props;

const copy =
  locale === "fr"
    ? {
        title: "Préférences cookies",
        description:
          "Acceptez, refusez ou modifiez les catégories de cookies à tout moment. Les cookies strictement nécessaires restent toujours actifs.",
        button: "Ouvrir les préférences cookies",
      }
    : {
        title: "Manage cookie preferences",
        description:
          "Accept, decline, or change cookie categories at any time. Strictly necessary cookies always stay on.",
        button: "Open cookie settings",
      };
---

<aside
  class="border-base-700 bg-base-900/60 mb-10 rounded-lg border p-6 md:p-8"
  aria-labelledby="cookie-settings-panel-title"
>
  <h2 id="cookie-settings-panel-title" class="text-base-50 text-lg font-semibold md:text-xl">
    {copy.title}
  </h2>
  <p class="text-base-300 mt-2 text-sm leading-relaxed md:text-base">{copy.description}</p>
  <div class="mt-5">
    <Button type="button" variant="primary" data-cc="show-preferencesModal">
      {copy.button}
    </Button>
  </div>
</aside>
