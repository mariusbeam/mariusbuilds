---
import { type CollectionEntry, getEntries } from "astro:content";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

import Category from "@components/Category/Category.astro";

import { getLocalizedRoute } from "@js/translationUtils";
import { formatDate } from "@js/textUtils";
import { getLocaleFromUrl } from "@js/localeUtils";

interface Props {
  post: CollectionEntry<"blog">;
  class?: string;
  rest?: Record<string, unknown>;
}

const { post, class: className, ...rest } = Astro.props as Props;
const { title, description, categories, authors, pubDate, heroImage } = post.data;

const currLocale = getLocaleFromUrl(Astro.url);
const authorsData = await getEntries(authors);
const postHref = getLocalizedRoute(currLocale, `/blog/${post.id}/`);
---

<article class:list={["group flex h-full w-full flex-col", className]} {...rest}>
  <a
    href={postHref}
    class="block aspect-[4/3] max-h-44 overflow-hidden rounded-md sm:max-h-48"
  >
    <Image
      src={heroImage}
      alt={`Cover for ${title}`}
      width={400}
      height={300}
      class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
    />
  </a>

  <div class="mt-3 flex flex-1 flex-col">
    <div class="flex flex-wrap gap-2">
      {categories.slice(0, 2).map((category) => <Category category={category} />)}
    </div>

    <p class="text-base-500 dark:text-base-400 mt-2 text-xs font-medium">
      {authorsData[0].data.name}
      <span class="mx-1">&bull;</span>
      {formatDate(pubDate, currLocale)}
    </p>

    <a href={postHref} class="decoration-primary-500 mt-1 hover:underline">
      <h3 class="dark:text-base-100 text-base font-bold leading-snug text-pretty md:text-lg">
        {title}
      </h3>
    </a>

    <p class="text-base-400 mt-2 line-clamp-2 text-sm font-medium">{description}</p>

    <a
      href={postHref}
      class="text-primary-500 hover:text-primary-600 mt-auto flex items-center gap-1 pt-3 text-sm font-semibold transition-colors"
    >
      Read post
      <Icon name="tabler/arrow-narrow-right" class="size-4" />
    </a>
  </div>
</article>
