---
import { type CollectionEntry, getEntries } from "astro:content";
import { Image } from "astro:assets";

import Category from "@components/Category/WorkCategory.astro";

import { getLocalizedRoute } from "@js/translationUtils";
import { formatDate, humanize } from "@js/textUtils";
import { getLocaleFromUrl } from "@js/localeUtils";

interface Props {
  post: CollectionEntry<"work">;
  showDescription?: boolean;
  class?: string;
}

const { post, showDescription = false, class: className, ...rest } = Astro.props as Props;
const { title, description, categories, authors, pubDate, heroImage } = post.data;

const currLocale = getLocaleFromUrl(Astro.url);
const authorsData = await getEntries(authors);
---

<article class={className} {...rest}>
  <a
    href={getLocalizedRoute(currLocale, `/work/${post.id}/`)}
    class="flex aspect-video max-h-96 shrink-0 justify-center overflow-hidden rounded-md sm:justify-normal"
  >
    <figure>
      <Image
        src={heroImage}
        alt={`Cover for ${title}`}
        height={700}
        quality="high"
        class="h-auto min-h-full w-full rounded-md object-cover transition-all duration-500"
      />
    </figure>
  </a>
  <div>
    <div class="mt-4 flex flex-wrap gap-4">
      {categories.map((category) => <Category category={category} />)}
    </div>

    <div class="text-base-500 dark:text-base-400 mt-3 flex flex-wrap gap-1 text-sm font-medium">
      <span>{authorsData[0]?.data.name}</span>
      <span aria-hidden="true">·</span>
      <time datetime={pubDate.toISOString()}>{formatDate(pubDate, currLocale)}</time>
    </div>

    <h2 class="dark:text-white mt-2 text-lg font-bold md:text-2xl">
      <a
        class="text-base-900 hover:text-primary-500 dark:text-white dark:hover:text-primary-500 transition-colors"
        href={getLocalizedRoute(currLocale, `/work/${post.id}/`)}
      >
        {title}
      </a>
    </h2>

    {
      showDescription && (
        <p class="description mt-2 text-sm font-medium md:text-base">{description}</p>
      )
    }
  </div>
</article>
