---
import { type CollectionEntry } from "astro:content";
import { ClientRouter } from "astro:transitions";

// component imports
import Seo from "@components/Seo/Seo.astro";

// data
import siteSettings from "@config/siteSettings.json";

export interface Props {
  type?: "blog" | "general" | undefined;
  title: string;
  description: string;
  image?: ImageMetadata;
  postFrontmatter?: CollectionEntry<"blog">["data"];
  authors?: CollectionEntry<"authors">[];
  noindex?: boolean;
}

const {
  type = "general",
  title,
  description,
  image,
  authors,
  postFrontmatter,
  noindex = false,
} = Astro.props as Props;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" initial-scale="1.0" />

<!-- Favicons (generated from src/assets/images/favicon.png) -->
<link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
<link rel="manifest" href="/favicons/site.webmanifest" />
<link rel="shortcut icon" href="/favicons/favicon-32x32.png" />
<meta name="msapplication-TileColor" content="#1c232d" />
<meta name="msapplication-config" content="/favicons/browserconfig.xml" />
<meta name="theme-color" content="#1c232d" />
<!-- end favicons -->

<!-- other -->
<meta name="generator" content={Astro.generator} />
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Site is dark-only; keep class on <html> after view transitions -->
<script is:inline>
  function applyDarkTheme() {
    document.documentElement.classList.add("dark");
    document.documentElement.style.colorScheme = "dark";
  }
  applyDarkTheme();
  document.addEventListener("astro:after-swap", applyDarkTheme);
</script>

<Seo
  type={type}
  title={title}
  description={description}
  image={image}
  authors={authors}
  postFrontmatter={postFrontmatter}
  noindex={noindex}
/>

<!-- no fallback as I saw issues with firefox fallback -->
{siteSettings.useViewTransitions && <ClientRouter fallback="none" />}
